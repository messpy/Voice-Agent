# Example env overrides loaded by voicechat.sh
# Copy to .env and edit secrets before running.
VOICECHAT_RUNNER=auto
# VOICECHAT_PYTHON=/path/to/python3.12
# VOICECHAT_REQUIREMENTS_CHECK=1
# XDG_CACHE_HOME=/tmp/voicechat-cache
# UV_CACHE_DIR=/tmp/voicechat-uv-cache
GOOGLE_APPLICATION_CREDENTIALS=~/.config/voicechat/google_stt.json
COHERE_API_KEY=your-cohere-api-key
